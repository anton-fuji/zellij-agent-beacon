layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
        pane size="25%" {
            // Use an absolute file: URL for local development.
            // `just init-layout` generates an ignored zellij.kdl with the correct path.
            plugin location="file:/absolute/path/to/zellij-agent-beacon/target/wasm32-wasip1/debug/zellij-agent-beacon.wasm"
        }
        pane
    }
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
